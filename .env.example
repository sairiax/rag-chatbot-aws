# ─────────────────────────────────────────────
# AWS Credentials & Region
# ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1

# ─────────────────────────────────────────────
# AWS Bedrock — Model IDs
# Usa inference profiles para evitar "on-demand throughput" errors
# ─────────────────────────────────────────────
# Embeddings (llamada directa con on-demand funciona):
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# LLM — usar el inference profile de tu región (prefijo eu. / us. / ap.):
# eu-west-1 disponibles: eu.anthropic.claude-3-5-sonnet-20240620-v1:0
#                         eu.amazon.nova-pro-v1:0
#                         eu.anthropic.claude-3-7-sonnet-20250219-v1:0
LLM_MODEL_ID=eu.anthropic.claude-3-5-sonnet-20240620-v1:0

# ─────────────────────────────────────────────
# ChromaDB
# ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=rag_university

# ─────────────────────────────────────────────
# Text Splitting
# ─────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ─────────────────────────────────────────────
# Retrieval
# ─────────────────────────────────────────────
TOP_K=5

# ─────────────────────────────────────────────
# LLM Generation Parameters
# ─────────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
